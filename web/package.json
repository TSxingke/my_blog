{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev-alt next dev --hostname 0.0.0.0 --port 3110",
    "dev:3000": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sync:supersplat-viewer": "mkdir -p public/supersplat-viewer && cp -f node_modules/@playcanvas/supersplat-viewer/public/index.html node_modules/@playcanvas/supersplat-viewer/public/index.css node_modules/@playcanvas/supersplat-viewer/public/index.js public/supersplat-viewer/",
    "sync:supersplat-editor": "node scripts/sync-supersplat-editor.mjs",
    "postinstall": "npm run sync:supersplat-viewer && npm run sync:supersplat-editor"
  },
  "dependencies": {
    "@playcanvas/supersplat-viewer": "^1.19.1",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.45",
    "next": "16.2.3",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
